    <route id="route_rt_n02_n01_n00" edges="e_n02_n01 e_n01_n00"/>
    <route id="route_rt_n12_n11_n10" edges="e_n12_n11 e_n11_n10"/>
    <route id="route_rt_n22_n21_n20" edges="e_n22_n21 e_n21_n20"/>
    <route id="route_rt_n22_n12_n11" edges="e_n22_n12 e_n12_n11"/>
    
    <!-- Left Turn Routes (10% of traffic) -->
    <route id="route_lt_n20_n10_n00" edges="e_n20_n10 e_n10_n00"/>
    <route id="route_lt_n00_n10_n20" edges="e_n00_n10 e_n10_n20"/>
    <route id="route_lt_n02_n12_n22" edges="e_n02_n12 e_n12_n22"/>
    <route id="route_lt_n22_n12_n02" edges="e_n22_n12 e_n12_n02"/>
    
    <!-- U-turn Routes (Two-wheelers only, 5% of traffic) -->
    <route id="route_uturn_n01_ew" edges="e_n00_n01 e_n01_n00"/>
    <route id="route_uturn_n10_ns" edges="e_n00_n10 e_n10_n00"/>
    <route id="route_uturn_n11_ew" edges="e_n10_n11 e_n11_n10"/>
