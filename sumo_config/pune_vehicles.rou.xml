<?xml version="1.0" encoding="UTF-8"?>
<!-- Pune Mixed Traffic Vehicle Type and Route Definitions -->
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">
    <!-- Vehicle Type Definitions for Indian Mixed Traffic -->
    <vType id="two_wheeler" length="2.0" maxSpeed="13.89" accel="2.5" decel="4.5" sigma="0.6" color="255,165,0" vClass="motorcycle"/>
    <vType id="auto_rickshaw" length="3.5" maxSpeed="11.11" accel="1.8" decel="3.5" sigma="0.5" color="255,255,0" vClass="taxi"/>
    <vType id="car" length="4.5" maxSpeed="13.89" accel="2.0" decel="4.0" sigma="0.4" color="0,128,255" vClass="passenger"/>
    <vType id="pedestrian_group" length="1.0" maxSpeed="1.4" accel="0.5" decel="1.0" sigma="0.3" color="0,255,0" vClass="pedestrian"/>
    
    <!-- Route Definitions for 3x3 Grid - All 12 Directional Paths -->
    
    <!-- NS Routes (North-South) -->
    <route id="route_n00_n20" edges="e_n00_n10 e_n10_n20"/>
    <route id="route_n20_n00" edges="e_n20_n10 e_n10_n00"/>
    <route id="route_n01_n21" edges="e_n01_n11 e_n11_n21"/>
