    <route id="route_n22_n02" edges="e_n22_n12 e_n12_n02"/>
    
    <!-- EW Routes (East-West) -->
    <route id="route_n00_n02" edges="e_n00_n01 e_n01_n02"/>
    <route id="route_n02_n00" edges="e_n02_n01 e_n01_n00"/>
    <route id="route_n10_n12" edges="e_n10_n11 e_n11_n12"/>
    <route id="route_n12_n10" edges="e_n12_n11 e_n11_n10"/>
    <route id="route_n20_n22" edges="e_n20_n21 e_n21_n22"/>
    <route id="route_n22_n20" edges="e_n22_n21 e_n21_n20"/>
    
    <!-- Right Turn Routes (20% of traffic) -->
    <route id="route_rt_n20_n10_n11" edges="e_n20_n10 e_n10_n11"/>
    <route id="route_rt_n21_n11_n12" edges="e_n21_n11 e_n11_n12"/>
